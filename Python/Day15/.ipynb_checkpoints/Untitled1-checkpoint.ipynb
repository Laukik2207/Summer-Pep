    "class Student:\n",
    "    college = \"lpu\"\n",
    "\n",
    "    def __init__(self,name,age):\n",
    "        self.name = name\n",
    "        self.age = age\n",
    "\n",
    "    def display(self):\n",
    "        print(self.name,self.age,self.college)\n",
    "\n",
    "\n",
    "\n",
    "s1 = Student(\"Rahul\",20)\n",
    "s2 = Student(\"Priya\",21)\n",
    "\n",
    "s1.display()\n",
    "s2.display()"
   ]
